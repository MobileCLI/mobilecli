# MobileCLI Social Media Automation Config
# Copy this to config.env and fill in your credentials

# === BLUESKY (free, no approval needed) ===
# Create an "App Password" at: bsky.app > Settings > App Passwords
BLUESKY_HANDLE=mobilecli.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# === TWITTER/X ===
# Option A: Free tier ($0) — text-only tweets, 1500/month
# Option B: Basic tier ($100/mo) — tweets with media
# Get keys at: developer.x.com
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# Set to "true" if you have Basic tier ($100/mo) for media uploads
TWITTER_HAS_MEDIA_ACCESS=false

# === REDDIT ===
# Create app at: reddit.com/prefs/apps (select "script" type)
# Reddit automation is semi-automated — generates drafts for manual review
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# === OPENAI (for content generation) ===
# Used to generate platform-specific post text from blog content
OPENAI_API_KEY=
